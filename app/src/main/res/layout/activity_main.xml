<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    tools:context=".MainActivity">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#1E1E1E"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/nifty_50"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nifty_price"
            android:paddingEnd="4dp"
            android:textColor="#4CAF50"
            tools:ignore="RtlSymmetry" />
    </LinearLayout>

    <TextView
        android:id="@+id/chartTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:text="RELIANCE Chart (Daily)"
        android:textColor="#BBBBBB"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout" />

    <!-- Candlestick Chart Mockup -->
    <LinearLayout
        android:id="@+id/chartMockup"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_margin="16dp"
        android:background="#1E1E1E"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="bottom"
        app:layout_constraintTop_toBottomOf="@id/chartTitle">

        <View android:layout_width="12dp" android:layout_height="80dp" android:layout_margin="4dp" android:background="#4CAF50" />
        <View android:layout_width="12dp" android:layout_height="100dp" android:layout_margin="4dp" android:background="#4CAF50" />
        <View android:layout_width="12dp" android:layout_height="90dp" android:layout_margin="4dp" android:background="#F44336" />
        <View android:layout_width="12dp" android:layout_height="120dp" android:layout_margin="4dp" android:background="#4CAF50" />
        <View android:layout_width="12dp" android:layout_height="110dp" android:layout_margin="4dp" android:background="#F44336" />
        <View android:layout_width="12dp" android:layout_height="140dp" android:layout_margin="4dp" android:background="#4CAF50" />
    </LinearLayout>

    <!-- Buy/Sell Buttons -->
    <LinearLayout
        android:id="@+id/orderButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/chartMockup">

        <Button
            android:id="@+id/btnBuy"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="BUY"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnSell"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="SELL"
            android:backgroundTint="#F44336"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <TextView
        android:id="@+id/watchlistTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        android:text="@string/welcome_message"
        android:textColor="#BBBBBB"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/orderButtons" />

</androidx.constraintlayout.widget.ConstraintLayout>